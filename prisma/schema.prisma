generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String?
  role         String        @default("USER")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  accounts     Account[]
  activities   ActivityLog[]
  sessions     Session[]
  vehicles     Vehicle[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Vehicle {
  id                 String           @id @default(uuid())
  userId             String
  type               String
  name               String
  brand              String
  model              String
  variant            String?
  registrationNumber String?
  vin                String?
  engineNumber       String?
  purchaseDate       DateTime
  purchasePrice      Decimal          @db.Decimal(12, 2)
  fuelType           String
  currentOdometer    Int
  insuranceExpiry    DateTime?
  pucExpiry          DateTime?
  warrantyExpiry     DateTime?
  notes              String?
  photos             String[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  documents          Document[]
  expenses           Expense[]
  fuelLogs           FuelLog[]
  maintenanceLogs    MaintenanceLog[]
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MaintenanceLog {
  id          String   @id @default(uuid())
  vehicleId   String
  date        DateTime
  odometer    Int
  workshop    String?
  mechanic    String?
  description String
  labourCost  Decimal  @default(0) @db.Decimal(10, 2)
  partsCost   Decimal  @default(0) @db.Decimal(10, 2)
  totalCost   Decimal  @db.Decimal(10, 2)
  notes       String?
  bills       String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([date])
}

model FuelLog {
  id            String   @id @default(uuid())
  vehicleId     String
  date          DateTime
  odometer      Int
  fuelStation   String?
  fuelType      String
  litres        Decimal  @db.Decimal(8, 2)
  pricePerLitre Decimal  @db.Decimal(8, 2)
  totalCost     Decimal  @db.Decimal(10, 2)
  mileage       Decimal? @db.Decimal(6, 2)
  costPerKm     Decimal? @db.Decimal(6, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([date])
}

model Expense {
  id          String   @id @default(uuid())
  vehicleId   String
  date        DateTime
  category    String
  description String?
  amount      Decimal  @db.Decimal(10, 2)
  billUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([category])
  @@index([date])
}

model Document {
  id         String    @id @default(uuid())
  vehicleId  String
  type       String
  name       String
  fileUrl    String
  fileType   String
  fileSize   Int
  expiryDate DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  vehicle    Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([type])
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   String?
  level     String
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([level])
  @@index([createdAt])
}
